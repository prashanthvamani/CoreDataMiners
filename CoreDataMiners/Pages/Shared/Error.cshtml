@model DataminersModel.ViewModels.ErrorViewModel

@{
    Layout = null;
    var errorMessage = ViewData["ErrorMessage"] as string;
}


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background-color: #f8f9fa;
    }

    .error-container {
        max-width: 750px;
        margin: 1% auto;
        padding: 0.25rem 0.75rem;
        background-color: #ffffff;
        border-radius: 1rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        text-align: center;
        animation: fadeIn 0.8s ease-in-out;
    }

    .error-icon {
        font-size: 4.5rem;
        color: #dc3545;
        animation: shake 1s infinite;
    }

    .emoji {
        font-size: 2rem;
        margin-left: 0.5rem;
    }

    .admin-details {
        text-align: left;
        margin-top: 1rem;
        background-color: #f1f3f5;
        border: 1px solid #dee2e6;
        padding: 1rem;
        border-radius: 0.5rem;
    }

    .detail-row {
        margin-bottom: 0.75rem;
    }

    .detail-label {
        font-weight: 600;
        display: inline-block;
        width: 150px;
    }

    pre {
        background-color: #e9ecef;
        padding: 1rem;
        border-radius: 0.5rem;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .btn-custom {
        margin-top: 2rem;
        font-size: 1rem;
        padding: 0.6rem 1.5rem;
    }

    @@keyframes shake {
        0% {
            transform: translateX(0);
        }

        25% {
            transform: translateX(-5px);
        }

        50% {
            transform: translateX(5px);
        }

        75% {
            transform: translateX(-5px);
        }

        100% {
            transform: translateX(0);
        }
    }

    @@keyframes fadeIn {
        0% {
            opacity: 0;
            transform: translateY(10px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>


<div class="container error-container">
    <div class="error-icon">
        <i class="fas fa-exclamation-triangle"></i>
    </div>

    <h1 class="display-6 mt-3">Oops! Something went wrong <span class="emoji">😟</span></h1>
    <p class="lead text-muted">We apologize for the inconvenience. Our team has been notified and is working on a fix. <span class="emoji">🛠️</span></p>

    @if (Model.ShowAdminDetails)
    {
        <div class="admin-details">
            <h5 class="mb-3">🧑‍💻 Technical Details</h5>

            <div class="detail-row"><span class="detail-label">Message:</span> @Model.Message</div>
            <div class="detail-row"><span class="detail-label">Type:</span> @Model.Type</div>
            <div class="detail-row"><span class="detail-label">Source:</span> @Model.Source</div>
            <div class="detail-row"><span class="detail-label">Occurred at:</span> @Model.Timestamp</div>
            <div class="detail-row"><span class="detail-label">Page:</span> @Model.PageUrl</div>

            @if (!string.IsNullOrEmpty(Model.InnerException))
            {
                <div class="detail-row"><span class="detail-label">Inner Exception:</span> @Model.InnerException</div>
            }
        </div>
    }
    <a asp-controller="RequestorLogin" asp-action="Index" class="btn btn-primary btn-custom">🏠 Return to Login</a>
</div>