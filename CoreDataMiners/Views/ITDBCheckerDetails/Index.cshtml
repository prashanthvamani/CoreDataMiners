    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.4/css/dataTables.bootstrap5.css" />
    <script src="https://code.jquery.com/jquery-3.7.1.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/2.3.4/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/2.3.4/js/dataTables.bootstrap5.js"></script>

    <script>
        $(document).ready(function() {
          var table = $('#clientsTable').DataTable({
            serverSide: true,
            processing: true,
            paging:true,
            searching:true,
            ordering: true,
            ajax: function(data, callback, settings) 
            {
                debugger;
              // Use DataTable's own search input:
              let searchValue = data.search.value;

              $.ajax({
                url: "/ITDBCheckerDetails/GetRequests",
                type: "GET",
                data: 
                {
                  search: searchValue,
                  page: (data.start / data.length) + 1,
                  pageSize: data.length
                },
                success: function(response) {
                  callback({
                    draw: data.draw,
                    recordsTotal: response.totalRecords,
                    recordsFiltered: response.totalRecords,
                    data: response.data
                  });
                },
                error: function(xhr, status, error) {
                  console.error("AJAX Error:", error);
                }
              });
            },
            columns: [
              { data: "requestID" },
              { data: "reqDateTime" },
              { data: "requestSource" },
              { data: "requestDataFromDate" },
              { data: "requestDataToDate" },
              { data: "dataRequestType" },
              { data: "customerType" },
              { data: "customerDesignation" },
              { data: "contactNo" },
              { data: "requestor" },
              { data: "fileName" },
              { data: "tat" },
              { data: "finalStatus" },
              { data: "assignTo" }
            ],
            paging: true,
            searching: true,
            ordering: true,
            dom: 'Bfrtip',
          });
        });
    </script>
</body>
