    <div class="container">
        <form method="post" asp-controller="ITDBCheckerDetails" asp-action="Index">
            <div class="input-group mb-3" style="max-width: 400px;">
                <input type="text" id="requestIdInput" name="RequestID" class="form-control" placeholder="Enter Request ID" aria-label="Request ID" />
                <button type="submit" class="btn btn-primary">Show Details</button>
            </div>
        </form>
        

        @if(Model.RequestIDSearch != null && Model.RequestIDSearch.Any())
        {
            <table class="form-control table-responsive table-striped table-sm">
                <thead>
                    <tr>
                        <th>Request ID</th>
                        <th>Request Date</th>
                        <th>Request Source</th>
                        <th>Customer Type</th>
                        <th>Customer Name</th>
                        <th>Initial Status</th>
                        <th>Assign Date</th>
                        <th>Completed Date</th>
                        <th>Verified By</th>
                        <th>Final Status</th>

                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.RequestIDSearch)
                    {
                        var statusClass = item.FinalStatus?.ToLower() == "open" ? "status-pill status-open" :
                        item.FinalStatus?.ToLower() == "wip" ? "status-pill status-wip" : "status-pill";

                        <tr>
                            <td>@item.RequestID</td>
                            <td>@(item.RequestDate.HasValue? item.RequestDate.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
                            <td>@item.RequestSource</td>
                            @*   <td>@(item.RequestDataFromDate.HasValue? item.RequestDataFromDate.Value.ToString("yyyy-MM-dd") : "")</td>
                        <td>@(item.RequestDataToDate.HasValue? item.RequestDataToDate.Value.ToString("yyyy-MM-dd") : "")</td> *@
                            <td>@item.CustomerType</td>
                            <td>@item.CustomerName</td>
                            <td>@item.InitialStatus</td>
                            <td>@item.AssginTo</td>
                            <td>@(item.AssignDate.HasValue? item.AssignDate.Value.ToString("yyyy-MM-dd") : "")</td>
                            <td>@item.CompletedDate</td>
                            <td>@item.VerifiedBy</td>
                            <td><span class="@statusClass">@item.FinalStatus</span></td>

                        </tr>
                    }
                    
                </tbody>
            </table>
        }
        @* else
        {
            <div class="alert alert-info">No data available or request not searched yet.</div>
        } *@

        
    </div>


